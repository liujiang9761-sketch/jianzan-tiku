.container { padding-bottom: 40rpx; }

.banner {
  height: 240rpx;
  margin: 0;
}
.banner-item {
  height: 240rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 48rpx;
}
.banner-title { font-size: 40rpx; font-weight: bold; color: #fff; }
.banner-sub   { font-size: 26rpx; color: rgba(255,255,255,.85); margin-top: 10rpx; }

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  padding: 32rpx 24rpx 16rpx;
}

.subject-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 24rpx;
}
.subject-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.05);
}
.subject-card:active { opacity: .75; }
.subject-icon { font-size: 52rpx; margin-bottom: 12rpx; }
.subject-name { font-size: 24rpx; color: #333; text-align: center; line-height: 1.4; }

.year-list { padding: 0 24rpx; }
.year-item {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.04);
}
.year-item:active { opacity: .75; }
.year-num   { font-size: 36rpx; font-weight: bold; color: #1677ff; }
.year-label { font-size: 26rpx; color: #666; margin-left: 12rpx; flex: 1; }
.year-arrow { font-size: 40rpx; color: #bbb; }
