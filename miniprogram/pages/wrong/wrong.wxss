.container { padding-bottom: 40rpx; }

.filter-bar { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 24rpx; }
.filter-value { color: #1677ff; font-size: 28rpx; }
.total-tip { font-size: 26rpx; color: #888; }
.blue { color: #1677ff; font-weight: bold; }

.q-item { margin-top: 16rpx; }
.q-meta { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; flex-wrap: wrap; }
.q-year, .q-subject { font-size: 22rpx; color: #888; }
.q-content { font-size: 28rpx; line-height: 1.7; color: #222; margin-bottom: 16rpx; white-space: pre-wrap; }

.opt-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  background: #f9f9f9;
}
.opt-correct { background: #f6ffed; }
.opt-wrong   { background: #fff2f0; }
.opt-key { font-weight: bold; font-size: 26rpx; min-width: 30rpx; }
.opt-text { font-size: 26rpx; color: #333; flex: 1; line-height: 1.5; }

.answer-compare {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
  margin: 12rpx 0;
  font-size: 26rpx;
}
.ans-wrong   { color: #ff4d4f; }
.ans-correct { color: #52c41a; }

.explain-toggle {
  color: #1677ff;
  font-size: 26rpx;
  margin-top: 12rpx;
  padding: 8rpx 0;
}
.explain-box {
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  margin-top: 8rpx;
  white-space: pre-wrap;
}

.load-more { text-align: center; color: #bbb; font-size: 24rpx; padding: 24rpx 0; }
.empty { text-align: center; padding: 100rpx 0; color: #999; font-size: 30rpx; line-height: 2; }
