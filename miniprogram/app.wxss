page {
  background: #f5f5f5;
  font-family: -apple-system, 'PingFang SC', sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.05);
}

.btn-primary {
  background: #1677ff;
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-ghost {
  border: 2rpx solid #1677ff;
  color: #1677ff;
  border-radius: 12rpx;
  padding: 18rpx 0;
  text-align: center;
  font-size: 30rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-single   { background: #e6f4ff; color: #1677ff; }
.tag-multiple { background: #f6ffed; color: #52c41a; }
.tag-case     { background: #fff7e6; color: #fa8c16; }

.divider { height: 1rpx; background: #f0f0f0; margin: 16rpx 0; }

.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}
